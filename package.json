{
  "name": "linguapop",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:extension": "pnpm --filter @linguapop/extension dev",
    "dev:web": "pnpm --filter @linguapop/web dev",
    "build:extension": "pnpm --filter @linguapop/extension build",
    "build:web": "pnpm --filter @linguapop/web build",
    "build:mobile": "pnpm --filter @linguapop/mobile build",
    "build:landing": "pnpm --filter @linguapop/landing build",
    "dev:landing": "pnpm --filter @linguapop/landing dev",
    "build": "pnpm -r build",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2"
  }
}
