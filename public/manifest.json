{
  "manifest_version": 3,
  "name": "LinguaPop",
  "version": "1.0.0",
  "description": "Smart language learning resource recommendations — radio, podcasts, YouTube and more, matched to your level and interests.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "LinguaPop"
  },
  "permissions": [],
  "host_permissions": [],
  "browser_specific_settings": {
    "gecko": {
      "id": "linguapop@faultless",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    },
    "gecko_android": {}
  }
}
